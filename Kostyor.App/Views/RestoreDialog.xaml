<Window x:Class="Kostyor.App.Views.RestoreDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Костёр — восстановление сессии"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="NoResize" ShowInTaskbar="False" Topmost="True"
        SizeToContent="WidthAndHeight" WindowStartupLocation="CenterScreen"
        FontFamily="{StaticResource SansFont}" UseLayoutRounding="True">

    <Border Margin="20" MouseLeftButtonDown="Card_Drag">
        <Border.Effect>
            <DropShadowEffect BlurRadius="48" ShadowDepth="16" Direction="270" Opacity="0.6" Color="Black"/>
        </Border.Effect>
        <Border Width="360" CornerRadius="20" Padding="24" BorderBrush="#1AFFFFFF" BorderThickness="1">
            <Border.Background>
                <RadialGradientBrush GradientOrigin="0.5,0" Center="0.5,0" RadiusX="0.9" RadiusY="0.9">
                    <GradientStop Color="#1d222c" Offset="0"/>
                    <GradientStop Color="#0d0f14" Offset="1"/>
                </RadialGradientBrush>
            </Border.Background>
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                    <Border Width="34" Height="34" CornerRadius="17" Background="#1F34D399" VerticalAlignment="Center">
                        <TextBlock Text="↻" FontSize="18" Foreground="#6ee7b7" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Восстановление сессии" FontWeight="Bold" FontSize="16" Foreground="#f1f5f9"
                               VerticalAlignment="Center" Margin="12,0,0,0"/>
                </StackPanel>

                <TextBlock x:Name="MessageText" Foreground="#cbd5e1" FontSize="13.5" TextWrapping="Wrap" LineHeight="20"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,22,0,0">
                    <Button Style="{StaticResource SecondaryButton}" Content="Нет" Width="96" Click="No_Click"/>
                    <Button Style="{StaticResource PrimaryButton}" Content="Восстановить" Width="140" Margin="10,0,0,0" Click="Yes_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Border>
</Window>
