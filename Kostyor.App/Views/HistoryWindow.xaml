<Window x:Class="Kostyor.App.Views.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Kostyor.App.ViewModels"
        Title="История — Костёр"
        WindowStyle="None" ResizeMode="NoResize" ShowInTaskbar="True" AllowsTransparency="True"
        Width="592" Height="600" WindowStartupLocation="CenterScreen"
        Background="Transparent" FontFamily="{StaticResource SansFont}" UseLayoutRounding="True">

    <Border Margin="16">
        <Border.Effect>
            <DropShadowEffect BlurRadius="40" ShadowDepth="14" Direction="270" Opacity="0.5" Color="Black"/>
        </Border.Effect>
        <Border CornerRadius="18" Background="#141820" BorderBrush="#2a3140" BorderThickness="1">
            <DockPanel>
                <!-- Заголовок -->
                <Border DockPanel.Dock="Top" CornerRadius="17,17,0,0" Background="#1a2130" MouseLeftButtonDown="Header_Drag">
                    <Grid>
                        <TextBlock Text="История встреч" FontWeight="Bold" FontSize="15" Foreground="#f1f5f9" Margin="20,13" VerticalAlignment="Center"/>
                        <Button Content="✕" HorizontalAlignment="Right" Width="44" Height="44" Foreground="#94a3b8"
                                Background="Transparent" BorderThickness="0" Cursor="Hand" FontSize="14" Click="Close_Click"/>
                    </Grid>
                </Border>

            <!-- Статистика -->
            <UniformGrid DockPanel.Dock="Top" Columns="3" Margin="16,16,16,8">
                <Border Background="#0DFFFFFF" CornerRadius="12" Padding="14" Margin="0,0,6,0">
                    <StackPanel>
                        <TextBlock Text="За неделю" Foreground="#8a93a3" FontSize="11.5"/>
                        <TextBlock Text="{Binding WeekTotalText}" Foreground="#f8fafc" FontWeight="Bold" FontSize="18" FontFamily="{StaticResource MonoFont}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
                <Border Background="#0DFFFFFF" CornerRadius="12" Padding="14" Margin="3,0">
                    <StackPanel>
                        <TextBlock Text="За месяц" Foreground="#8a93a3" FontSize="11.5"/>
                        <TextBlock Text="{Binding MonthTotalText}" Foreground="#f8fafc" FontWeight="Bold" FontSize="18" FontFamily="{StaticResource MonoFont}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
                <Border Background="#0DFFFFFF" CornerRadius="12" Padding="14" Margin="6,0,0,0">
                    <StackPanel>
                        <TextBlock Text="Бесполезные" Foreground="#8a93a3" FontSize="11.5"/>
                        <TextBlock Text="{Binding ThumbsDownText}" Foreground="#fda4af" FontWeight="Bold" FontSize="12.5" TextWrapping="Wrap" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Действия -->
            <Grid DockPanel.Dock="Bottom" Margin="16,8,16,16">
                <Button Style="{StaticResource SecondaryButton}" Content="Экспорт в CSV" Width="160" HorizontalAlignment="Left"
                        Command="{Binding ExportCsvCommand}"/>
            </Grid>

            <!-- Список -->
            <Grid Margin="16,8">
                <TextBlock Text="{Binding EmptyHintText}" Foreground="#8a93a3" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Rows}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:HistoryViewModel+HistoryRow}">
                                <Border Background="#0AFFFFFF" CornerRadius="10" Padding="12,10" Margin="0,0,0,7">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding DateText}" Foreground="#e8edf3" FontWeight="SemiBold" FontSize="13"/>
                                                <TextBlock Text="{Binding WorthText}" Margin="8,0,0,0" FontSize="13"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding Composition}" Foreground="#8a93a3" FontSize="11.5" Margin="0,3,0,0" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                            <TextBlock Text="{Binding RubText}" Foreground="#f8fafc" FontWeight="Bold" FontSize="15" FontFamily="{StaticResource MonoFont}" TextAlignment="Right"/>
                                            <TextBlock Text="{Binding DurationText}" Foreground="#8a93a3" FontSize="11.5" FontFamily="{StaticResource MonoFont}" TextAlignment="Right" Margin="0,3,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
            </DockPanel>
        </Border>
    </Border>
</Window>
