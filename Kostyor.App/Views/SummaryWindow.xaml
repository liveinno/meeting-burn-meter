<Window x:Class="Kostyor.App.Views.SummaryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Kostyor.App.ViewModels"
        Title="Итог встречи — Костёр"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="NoResize" ShowInTaskbar="True" Topmost="True"
        SizeToContent="WidthAndHeight" WindowStartupLocation="CenterScreen"
        FontFamily="{StaticResource SansFont}" UseLayoutRounding="True">

    <!-- Только карточка, без полноэкранной подложки (BUGS.md). -->
    <Border Margin="24" MouseLeftButtonDown="Card_MouseLeftButtonDown">
        <Border.Effect>
            <DropShadowEffect BlurRadius="60" ShadowDepth="20" Direction="270" Opacity="0.65" Color="Black"/>
        </Border.Effect>
        <Border x:Name="CardRoot" Width="384" CornerRadius="26" Padding="28"
                BorderBrush="#1AFFFFFF" BorderThickness="1">
            <Border.Background>
                <RadialGradientBrush GradientOrigin="0.5,0" Center="0.5,0" RadiusX="0.9" RadiusY="0.9">
                    <GradientStop Color="#1d222c" Offset="0"/>
                    <GradientStop Color="#0d0f14" Offset="1"/>
                </RadialGradientBrush>
            </Border.Background>
            <Grid>
            <StackPanel>
                <TextBlock Text="ИТОГ ВСТРЕЧИ «КОСТЁР»" FontSize="12" FontWeight="Bold"
                           Foreground="#8a93a3" Margin="0,0,28,0"/>

                <StackPanel Orientation="Horizontal" Margin="0,10,0,2">
                    <TextBlock Text="{Binding FinalRubText}" FontFamily="{StaticResource MonoFont}"
                               FontWeight="Bold" FontSize="42" Foreground="#f8fafc"/>
                    <TextBlock Text="₽" FontSize="24" Foreground="#94a3b8" VerticalAlignment="Bottom" Margin="6,0,0,6"/>
                </StackPanel>

                <TextBlock Text="{Binding ConversionText}" FontSize="14" FontWeight="SemiBold" Foreground="#8a93a3"/>

                <TextBlock Text="СОЖГЛИ, КАК" FontSize="11.5" FontWeight="Bold" Foreground="#8a93a3" Margin="0,18,0,9"/>
                <ItemsControl ItemsSource="{Binding Equivalents}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:SummaryViewModel+EquivalentItem}">
                            <Border Background="{Binding Bg}" BorderBrush="{Binding Border}" BorderThickness="1"
                                    CornerRadius="12" Padding="13,8" Margin="0,0,8,8">
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="{Binding Icon, Converter={StaticResource EmojiToImage}}"
                                           Width="17" Height="17" VerticalAlignment="Center" SnapsToDevicePixels="True"/>
                                    <TextBlock Text="{Binding Text}" FontWeight="Bold" FontSize="14"
                                               Foreground="{Binding Fg}" Margin="7,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <UniformGrid Columns="2" Margin="0,14,0,0">
                    <Border Background="#0AFFFFFF" CornerRadius="14" Padding="15,13" Margin="0,0,6,12">
                        <StackPanel>
                            <TextBlock Text="Длительность" FontSize="11.5" Foreground="#8a93a3" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding DurationText}" FontFamily="{StaticResource MonoFont}" FontSize="19" FontWeight="Bold" Foreground="#e8edf3"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#0AFFFFFF" CornerRadius="14" Padding="15,13" Margin="6,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Человеко-часы" FontSize="11.5" Foreground="#8a93a3" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding PersonHoursText}" FontFamily="{StaticResource MonoFont}" FontSize="19" FontWeight="Bold" Foreground="#e8edf3"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#0AFFFFFF" CornerRadius="14" Padding="15,13" Margin="0,0,6,0">
                        <StackPanel>
                            <TextBlock Text="Участников" FontSize="11.5" Foreground="#8a93a3" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding ParticipantsText}" FontFamily="{StaticResource MonoFont}" FontSize="19" FontWeight="Bold" Foreground="#e8edf3"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#0AFFFFFF" CornerRadius="14" Padding="15,13" Margin="6,0,0,0">
                        <StackPanel>
                            <TextBlock Text="Скорость" FontSize="11.5" Foreground="#8a93a3" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding BurnText}" FontFamily="{StaticResource MonoFont}" FontSize="19" FontWeight="Bold" Foreground="#e8edf3"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <!-- Оценка «оно того стоило?» (ТЗ §4) -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,18,0,4">
                    <TextBlock Text="Оно того стоило?" Foreground="#8a93a3" FontSize="13" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <Button Command="{Binding ThumbUpCommand}" Width="46" Height="38" Cursor="Hand" Margin="0,0,8,0">
                        <Button.Content>
                            <Image Source="{StaticResource Emoji.ThumbUp}" Width="22" Height="22"/>
                        </Button.Content>
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="b" Background="#0DFFFFFF" BorderBrush="#1FFFFFFF" BorderThickness="1" CornerRadius="11">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <DataTrigger Binding="{Binding WorthIt}" Value="True">
                                        <Setter TargetName="b" Property="Background" Value="#2634d399"/>
                                        <Setter TargetName="b" Property="BorderBrush" Value="#8034d399"/>
                                    </DataTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Command="{Binding ThumbDownCommand}" Width="46" Height="38" Cursor="Hand">
                        <Button.Content>
                            <Image Source="{StaticResource Emoji.ThumbDown}" Width="22" Height="22"/>
                        </Button.Content>
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="b" Background="#0DFFFFFF" BorderBrush="#1FFFFFFF" BorderThickness="1" CornerRadius="11">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <DataTrigger Binding="{Binding WorthIt}" Value="False">
                                        <Setter TargetName="b" Property="Background" Value="#26f43f5e"/>
                                        <Setter TargetName="b" Property="BorderBrush" Value="#80f43f5e"/>
                                    </DataTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>

                <Button Style="{StaticResource PrimaryButton}" Content="{Binding CopyLabel}"
                        Command="{Binding CopyCommand}" Margin="0,14,0,9"/>
                <Button Style="{StaticResource SecondaryButton}" Content="Сохранить картинкой (PNG)"
                        Command="{Binding SavePngCommand}" Margin="0,0,0,9"/>
                <Button Style="{StaticResource SecondaryButton}" Content="Новая встреча"
                        Command="{Binding ResetCommand}"/>
            </StackPanel>
            <Button Content="✕" Width="30" Height="30" HorizontalAlignment="Right" VerticalAlignment="Top"
                    Foreground="#94a3b8" Cursor="Hand" FontSize="14" ToolTip="Закрыть" Click="Close_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="cb" Background="#12FFFFFF" CornerRadius="15">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="cb" Property="Background" Value="#26F43F5E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            </Grid>
        </Border>
    </Border>
</Window>
