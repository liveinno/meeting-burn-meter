<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:conv="clr-namespace:Kostyor.App.Converters">

    <!-- WPF TextBlock не рисует цветные COLR-эмодзи (выходят ч/б). Заменяем ключевые эмодзи
         самодельными цветными векторными иконками (без внешних зависимостей). -->

    <conv:EmojiToImageConverter x:Key="EmojiToImage"/>

    <!-- 🍕 Пицца (кусок остриём вверх: жёлтый сыр, коричневая корочка, красная пепперони) -->
    <DrawingImage x:Key="Emoji.Pizza">
        <DrawingImage.Drawing>
            <DrawingGroup>
                <!-- Корочка (широкая дуга снизу) -->
                <GeometryDrawing Brush="#D99A3A" Geometry="F1 M3.5,17.5 Q12,21.5 20.5,17.5 L19.2,14.6 Q12,18.2 4.8,14.6 Z"/>
                <!-- Сыр -->
                <GeometryDrawing Brush="#F7C948" Geometry="F1 M12,2.5 L19.2,15 Q12,18.4 4.8,15 Z"/>
                <!-- Пепперони -->
                <GeometryDrawing Brush="#D63C2E">
                    <GeometryDrawing.Geometry>
                        <GeometryGroup>
                            <EllipseGeometry Center="9.2,9.5" RadiusX="1.9" RadiusY="1.9"/>
                            <EllipseGeometry Center="14.4,11.2" RadiusX="1.9" RadiusY="1.9"/>
                            <EllipseGeometry Center="11.2,14" RadiusX="1.7" RadiusY="1.7"/>
                        </GeometryGroup>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>

    <!-- 📱 Смартфон -->
    <DrawingImage x:Key="Emoji.Phone">
        <DrawingImage.Drawing>
            <DrawingGroup>
                <GeometryDrawing Brush="#60A5FA" Geometry="F1 M6.5,2 L17.5,2 A2.5,2.5 0 0 1 20,4.5 L20,19.5 A2.5,2.5 0 0 1 17.5,22 L6.5,22 A2.5,2.5 0 0 1 4,19.5 L4,4.5 A2.5,2.5 0 0 1 6.5,2 Z"/>
                <GeometryDrawing Brush="#0D0F14" Geometry="M6,5 L18,5 L18,17.5 L6,17.5 Z"/>
                <GeometryDrawing Brush="#BFDBFE">
                    <GeometryDrawing.Geometry><EllipseGeometry Center="12,19.7" RadiusX="1" RadiusY="1"/></GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>

    <!-- 💻 Ноутбук -->
    <DrawingImage x:Key="Emoji.Laptop">
        <DrawingImage.Drawing>
            <DrawingGroup>
                <GeometryDrawing Brush="#C3CBD5" Geometry="F1 M5,4 L19,4 A1,1 0 0 1 20,5 L20,13 L4,13 L4,5 A1,1 0 0 1 5,4 Z"/>
                <GeometryDrawing Brush="#10151D" Geometry="M5.5,5.5 L18.5,5.5 L18.5,11.5 L5.5,11.5 Z"/>
                <GeometryDrawing Brush="#AAB3BE" Geometry="F1 M2.5,14.5 L21.5,14.5 L22.5,18 A0.6,0.6 0 0 1 22,18.6 L2,18.6 A0.6,0.6 0 0 1 1.5,18 Z"/>
            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>

    <!-- 🔥 Огонь -->
    <DrawingImage x:Key="Emoji.Fire">
        <DrawingImage.Drawing>
            <DrawingGroup>
                <GeometryDrawing Brush="#FB923C" Geometry="F1 M12,2 C9,6 6,8.5 6,13 A6,6 0 0 0 18,13 C18,9 15,7 12,2 Z"/>
                <GeometryDrawing Brush="#FBBF24" Geometry="F1 M12,8.5 C10.5,10.5 9.5,11.5 9.5,13.8 A2.5,2.5 0 0 0 14.5,13.8 C14.5,11.5 13.5,10.5 12,8.5 Z"/>
            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>

    <!-- 👍 Палец вверх (Material thumb_up, жёлтый как эмодзи) -->
    <DrawingImage x:Key="Emoji.ThumbUp">
        <DrawingImage.Drawing>
            <GeometryDrawing Brush="#FCD34D" Geometry="F1 M1,21 L5,21 L5,9 L1,9 Z M23,10 C23,8.9 22.1,8 21,8 L14.69,8 L15.64,3.43 L15.67,3.11 C15.67,2.7 15.5,2.32 15.23,2.05 L14.17,1 L7.59,7.59 C7.22,7.95 7,8.45 7,9 L7,19 C7,20.1 7.9,21 9,21 L18,21 C18.83,21 19.54,20.5 19.84,19.78 L22.86,12.73 C22.95,12.5 23,12.26 23,12 Z"/>
        </DrawingImage.Drawing>
    </DrawingImage>

    <!-- 👎 Палец вниз (Material thumb_down) -->
    <DrawingImage x:Key="Emoji.ThumbDown">
        <DrawingImage.Drawing>
            <GeometryDrawing Brush="#FCD34D" Geometry="F1 M15,3 L6,3 C5.17,3 4.46,3.5 4.16,4.22 L1.14,11.27 C1.05,11.5 1,11.74 1,12 L1,14 C1,15.1 1.9,16 3,16 L9.31,16 L8.36,20.57 L8.33,20.89 C8.33,21.3 8.5,21.68 8.77,21.95 L9.83,23 L16.41,16.41 C16.78,16.05 17,15.55 17,15 L17,5 C17,3.9 16.1,3 15,3 Z M19,3 L19,15 L23,15 L23,3 Z"/>
        </DrawingImage.Drawing>
    </DrawingImage>

</ResourceDictionary>
