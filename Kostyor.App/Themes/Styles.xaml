<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <BooleanToVisibilityConverter x:Key="BoolToVis"/>

    <!-- ===== Тёмное контекстное меню (трей + правый клик по кругу) ===== -->
    <Style TargetType="ContextMenu">
        <Setter Property="Foreground" Value="#e2e8f0"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="FontSize" Value="13.5"/>
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="HasDropShadow" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContextMenu">
                    <Border Background="#1b1f28" BorderBrush="#2f3542" BorderThickness="1" CornerRadius="12" Padding="6">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="28" ShadowDepth="8" Direction="270" Opacity="0.55" Color="Black"/>
                        </Border.Effect>
                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Cycle"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="MenuItem">
        <Setter Property="Foreground" Value="#dbe2ea"/>
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="MenuItem">
                    <Border x:Name="bd" Background="Transparent" CornerRadius="8" Padding="13,8" Margin="0,1">
                        <ContentPresenter ContentSource="Header" VerticalAlignment="Center" RecognizesAccessKey="True"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="#2634d399"/>
                            <Setter Property="Foreground" Value="#eafff5"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="#5b6472"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="Separator">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Separator">
                    <Border Height="1" Background="#2b313d" Margin="10,5"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Шрифты: Manrope/JetBrains Mono с системными фолбэками (см. README). -->
    <FontFamily x:Key="SansFont">Manrope, Segoe UI</FontFamily>
    <FontFamily x:Key="MonoFont">JetBrains Mono, Cascadia Mono, Consolas</FontFamily>

    <!-- Палитра из дизайна Костёр.dc.html -->
    <SolidColorBrush x:Key="TimeBrush" Color="#cbd5e1"/>
    <SolidColorBrush x:Key="AmountBrush" Color="#f8fafc"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="#94a3b8"/>
    <SolidColorBrush x:Key="ConvBrush" Color="#8a93a3"/>
    <SolidColorBrush x:Key="IconFgBrush" Color="#e2e8f0"/>
    <SolidColorBrush x:Key="PanelTitleBrush" Color="#f1f5f9"/>
    <SolidColorBrush x:Key="DarkIconBrush" Color="#0c0e13"/>

    <SolidColorBrush x:Key="IconBtnBorder" Color="#21FFFFFF"/>
    <SolidColorBrush x:Key="IconBtnBg" Color="#0FFFFFFF"/>
    <SolidColorBrush x:Key="IconBtnHover" Color="#1AFFFFFF"/>
    <SolidColorBrush x:Key="StepperBorder" Color="#1FFFFFFF"/>
    <SolidColorBrush x:Key="StepperBg" Color="#0DFFFFFF"/>
    <SolidColorBrush x:Key="StopBorder" Color="#66F43F5E"/>
    <SolidColorBrush x:Key="StopBg" Color="#24F43F5E"/>

    <!-- Круглый фон счётчика: radial-gradient(circle at 50% 30%,#1c2029,#0b0d12) -->
    <RadialGradientBrush x:Key="CircleBg" GradientOrigin="0.5,0.3" Center="0.5,0.3" RadiusX="0.85" RadiusY="0.85">
        <GradientStop Color="#1c2029" Offset="0"/>
        <GradientStop Color="#0b0d12" Offset="1"/>
    </RadialGradientBrush>

    <!-- Кнопка play/pause: linear-gradient(135deg,#f4f7fb,#c9d2de) -->
    <LinearGradientBrush x:Key="PlayBg" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#f4f7fb" Offset="0"/>
        <GradientStop Color="#c9d2de" Offset="1"/>
    </LinearGradientBrush>

    <!-- Круглая иконочная кнопка (44px) -->
    <Style x:Key="IconButton" TargetType="Button">
        <Setter Property="Width" Value="44"/>
        <Setter Property="Height" Value="44"/>
        <Setter Property="Foreground" Value="{StaticResource IconFgBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource SansFont}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" CornerRadius="22" Background="{StaticResource IconBtnBg}"
                            BorderBrush="{StaticResource IconBtnBorder}" BorderThickness="1">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource IconBtnHover}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Кнопка play/pause (66px) -->
    <Style x:Key="PlayButton" TargetType="Button">
        <Setter Property="Width" Value="66"/>
        <Setter Property="Height" Value="66"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" CornerRadius="33" Background="{StaticResource PlayBg}">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="26" ShadowDepth="10" Direction="270" Opacity="0.5" Color="Black"/>
                        </Border.Effect>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Opacity" Value="0.92"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Кнопка стоп (44px, красная) -->
    <Style x:Key="StopButton" TargetType="Button">
        <Setter Property="Width" Value="44"/>
        <Setter Property="Height" Value="44"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" CornerRadius="22" Background="{StaticResource StopBg}"
                            BorderBrush="{StaticResource StopBorder}" BorderThickness="1">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Степпер (крупнее — под увеличенные шрифты панели) -->
    <Style x:Key="StepperButton" TargetType="Button">
        <Setter Property="Width" Value="38"/>
        <Setter Property="Height" Value="38"/>
        <Setter Property="Foreground" Value="{StaticResource IconFgBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource SansFont}"/>
        <Setter Property="FontSize" Value="24"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" CornerRadius="9" Background="{StaticResource StepperBg}"
                            BorderBrush="{StaticResource StepperBorder}" BorderThickness="1">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource IconBtnHover}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Кнопка «действие» (светлая, для итога/настроек) -->
    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="Height" Value="44"/>
        <Setter Property="Foreground" Value="#0c0e13"/>
        <Setter Property="FontFamily" Value="{StaticResource SansFont}"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" CornerRadius="13" Background="#f4f7fb">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Opacity" Value="0.9"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Кнопка «вторичная» (контур) -->
    <Style x:Key="SecondaryButton" TargetType="Button">
        <Setter Property="Height" Value="42"/>
        <Setter Property="Foreground" Value="#cbd5e1"/>
        <Setter Property="FontFamily" Value="{StaticResource SansFont}"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="FontSize" Value="13.5"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" CornerRadius="13" Background="Transparent"
                            BorderBrush="{StaticResource StepperBorder}" BorderThickness="1">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource IconBtnBg}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
